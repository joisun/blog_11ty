<!DOCTYPE html>
<html lang="{{ site.language }}">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="color-scheme" content="light dark">
        <meta
            name="theme-color"
            content="#fff"
            media="(prefers-color-scheme: light)"
        >
        <meta
            name="theme-color"
            content="#111113"
            media="(prefers-color-scheme: dark)"
        >

        {# SEO Meta Tags #}
        <title>{{ title or site.title }}</title>
        <meta name="description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
        <meta name="author" content="Joisun">
        <meta name="keywords" content="{% if tags %}{{ tags | join(', ') }}{% else %}{{ site.keywords }}{% endif %}">

        {# Open Graph Meta Tags #}
        <meta property="og:title" content="{{ title or site.title }}">
        <meta property="og:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
        <meta property="og:image" content="{{ '/assets/ogimage.png' | url }}">
        <meta property="og:url" content="{{ site.url }}{{ page.url }}">
        <meta property="og:type" content="article">
        <meta property="og:site_name" content="Joisun's Blog">

        {# Twitter Card Meta Tags #}
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ title or site.title }}">
        <meta name="twitter:description" content="{% if description %}{{ description }}{% else %}{{ site.description }}{% endif %}">
        <meta name="twitter:image" content="{{ '/assets/ogimage.png' | url }}">

        {# Favicon and Apple Touch Icons #}
        <link
            rel="apple-touch-icon"
            type="image/svg+xml"
            href="{{ '/assets/apple-touch-icon.svg' | url }}"
        >
        <link
            rel="apple-touch-startup-image"
            type="image/svg+xml"
            href="{{ '/assets/apple-touch-icon.svg' | url }}"
        >
        <meta name="apple-mobile-web-app-title" content="Joisun's Blog">
        <link
            rel="icon"
            href="/favicon-light.svg"
            type="image/svg+xml"
        >

        {# Other Meta Tags #}
        <meta name="generator" content="{{ eleventy.generator }}">
        {% if site.url in page.url %}
        <link rel="canonical" href="{{ site.url }}{{ page.url }}">
        <link
            rel="alternate"
            href="{{ site.alternate_url }}{{ page.url }}"
            hreflang="{{ site.language }}"
        >
        {% else %}
        <link rel="canonical" href="{{ site.alternate_url }}{{ page.url }}">
        <link
            rel="alternate"
            href="{{ site.url }}{{ page.url }}"
            hreflang="{{ site.language }}"
        >
        {% endif %}

        {# 不算子站点统计：https://ibruce.info/2015/04/04/busuanzi/ #}
        <script defer src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>
        <link rel="stylesheet" href="{{ '/css/main.css' | url }}">
        {% if page.url == '/' %}
        <script>
                if (location.hash)
                    window.location = `/admin/#${
                        location
                            .href
                            .split("#")
                            .pop()
                    }`
        </script>
        {% endif %}
        {# google analysis: 域名： #}
        <script defer src="https://www.googletagmanager.com/gtag/js?id={{ site.google_analytics_id }}"></script>
        <script>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', '{{ site.google_analytics_id }}');
        </script>

        {# mermaid插件 https://github.com/KevinGimbel/eleventy-plugin-mermaid #}
        {% mermaid_js %}

        {# img-previewer 图片查看器 #}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/img-previewer@2.1.6/dist/index.css">
        <script src="https://cdn.jsdelivr.net/npm/img-previewer@2.1.6/dist/img-previewer.min.js"></script>
    </head>
    <body>
        {% import "icons.njk" as icons %}

        <nav class="main-nav" aria-label="Main navigation">
            <span class="breadcrumb">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 5l7 7-7 7"
                    />
                </svg>
                <span class="breadcrumb-text">
                    {% if page.url == '/' %}
                    Home
                    {% elif page.url == '/archieve/' %}
                    Archive
                    {% elif page.url == '/tags/' %}
                    Tags
                    {% elif page.url == '/routine/' %}
                    Routine
                    {% elif page.url.startsWith('/posts/') %}
                    Post
                    {% elif title %}
                    {{ title }}
                    {% else %}
                    {{ page.url | replace('/', '') | replace('-', ' ') | title }}
                    {% endif %}
                </span>
            </span>
            {% if page.url != '/' %}
            <a href="{{ '/' | url }}" class="nav-link">
                {{ icons.home() }}
                <span>Home</span>
            </a>
            {% endif %}
            {% if page.url != '/archieve/' %}
            <a href="{{ '/archieve/' | url }}" class="nav-link">
                {{ icons.archive() }}
                <span>Archive</span>
            </a>
            {% endif %}
            {% if page.url != '/tags/' %}
            <a href="{{ '/tags/' | url }}" class="nav-link">
                {{ icons.tag() }}
                <span>Tags</span>
            </a>
            {% endif %}
            {% if page.url != '/routine/' %}
            <a href="{{ '/routine/' | url }}" class="nav-link">
                {{ icons.clock() }}
                <span>Routine</span>
            </a>
            {% endif %}
            {% if page.url != '/hikes/' %}
            <a href="{{ '/hikes/' | url }}" class="nav-link">
                {{ icons.hike() }}
                <span>Hikes</span>
            </a>
            {% endif %}
            <button
                id="search-trigger"
                onclick="openSearch()"
                title="Search (Cmd+K)"
                aria-label="Open search dialog"
                type="button"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                    />
                </svg>
                <span>Search</span>
            </button>
            <button
                id="color-mode"
                title="Toggle dark mode"
                aria-label="Toggle dark mode"
                role="switch"
                aria-checked="false"
            >
                <img
                    alt=""
                    id="randomImage"
                    title=""
                    loading="lazy"
                    style="pointer-events: none;"
                >
            </button>
        </nav>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const images = "meow_whacky_rainbow.gif,meow_coffeespitting.gif,meow_enjoy-snow.gif,meow_dab.gif,meow_code.gif,meow_dj.png".split(",")
                const randomImage = images[Math.floor(Math.random() * images.length)];
                const imgElement = document.getElementById('randomImage');

                // 加载失败时隐藏
                imgElement.onerror = function() {
                    imgElement.style.display = 'none';
                };

                // 加载成功后显示
                imgElement.onload = function() {
                    imgElement.style.display = 'block';
                };

                // 设置 src 触发加载
                imgElement.src = '/assets/ani/' + randomImage;
            });
        </script>

        <main id="main-content" role="main">
            {{ content | safe }}
        </main>
        {#
        <script src="https://cdn.bootcdn.net/ajax/libs/eruda/2.3.3/eruda.min.js"></script>
        <script>eruda.init();</script>
        #}
        {% include "search.njk" %}
        <script>

            /**
            * 设定一些全局变量 - START --------------------------------------------------------------------------
            */

            // 判断是否为生产环境，
            window.__isProduction = window.location.hostname !== 'localhost' && window.location.hostname !== '127.0.0.1';

            /**
            * 设定一些全局变量 - END --------------------------------------------------------------------------
            */

            const colorModeBtn = document.querySelector('#color-mode')
            const DarkBtnColor = '#fff'
            const LightBtnColor = '#000'
            colorModeBtn.addEventListener('click',()=>{
                const hasDarkClass = document.documentElement.classList.toggle('dark')
                /*
                    if(hasDarkClass){
                        colorModeBtn.style.backgroundColor = DarkBtnColor
                    }else{
                        colorModeBtn.style.backgroundColor = LightBtnColor
                    }
                */

                setTheme(hasDarkClass)
                localStorage.setItem('mode', hasDarkClass ? 'dark' : 'light')
                // 更新 ARIA 属性
                colorModeBtn.setAttribute('aria-checked', hasDarkClass ? 'true' : 'false')
            })

            function sendMessage(message) {
                const iframe = document.querySelector('iframe.giscus-frame');
                if (!iframe) return;
                iframe.contentWindow.postMessage({ giscus: message }, 'https://giscus.app');
            }

            function setTheme(isDark, animation=true){
                const cacheTransitionSetting = document.documentElement.style.transition
                if(!animation){
                    document.documentElement.style.transition = 'none'
                }
                if(isDark){
                  document.documentElement.classList.add('dark')
                  colorModeBtn.style.backgroundColor = DarkBtnColor
                }else{
                  document.documentElement.classList.remove('dark')
                  colorModeBtn.style.backgroundColor = LightBtnColor
                }
                setTimeout(()=>{
                    document.documentElement.style.transition = cacheTransitionSetting
                })

                updateFavicon(isDark)

                sendMessage({
                    setConfig: {
                    theme: isDark ? 'dark' : 'light'
                    }
                });

                document.dispatchEvent(new CustomEvent('theme-change', { detail: { dark: isDark } }));
            }

            function updateFavicon(isDark){
                const link = document.querySelector("link[rel~='icon']");
                link.href = isDark ? "/favicon-dark.svg" : "/favicon-light.svg";
            }

            function setDefaultThemeColor(){
                // 先看用户有没有历史设定颜色，如果没有，用操作系统默认颜色
                const historySettingMode = localStorage.getItem('mode')
                let isDark = false
                if(historySettingMode){
                    isDark = historySettingMode === 'dark'
                }else{
                    //如果用户没有设置过颜色，那么使用系统默认颜色
                    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                        // dark mode
                        isDark = true
                    }else{
                        isDark = false
                    }
                }
                window.isDark = isDark
                setTheme(isDark, false)
                // 初始化 ARIA 属性
                colorModeBtn.setAttribute('aria-checked', isDark ? 'true' : 'false')
            }
            setDefaultThemeColor()

            //监听系统颜色修改
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', event => {
                const isDark = event.matches;
                setTheme(isDark)
                // 移除用户颜色模式设定
                localStorage.removeItem('mode')
            });

            // 监听 giscus 内部时间，同步有颜色主题
            window.addEventListener('message', handleMessage);
            function handleMessage(event) {
            if (event.origin !== 'https://giscus.app') return;
            if (!(typeof event.data === 'object' && event.data.giscus)) return;
            const giscusData = event.data.giscus;
            sendMessage({
                    setConfig: {
                    theme: window.isDark ? 'dark' : 'light'
                    }
            });
            }

        </script>
        </main>
        <footer id="footer">
            {% include "footer.njk" %}
        </footer>

        <script>
            const previewTarget = document.querySelector('.prose');
            if (previewTarget) {
                new ImgPreviewer('.prose', { bubblingLevel: 1 });
            }
        </script>
    </body>
</html>
