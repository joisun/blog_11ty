---
layout: base.njk
---

<div id="homepage">
    <main>
        {% set top = homepage.recentPostsMaxLength %}

        {# 直接从 collections.all 获取所有文章，避免重复 #}
        {% set allPosts = [] %}
        {% for item in collections.all %}
        {% if item.inputPath.startsWith('./src/posts/') and item.inputPath.endsWith('.md') %}
        {% set allPosts = (allPosts.push(item), allPosts) %}
        {% endif %}
        {% endfor %}

        {% set sorted_posts = allPosts | sort(attribute='date') | reverse %}
        {% set posts = sorted_posts.slice(0, top) %}

        <div class="timeline">
            {% for post in posts %}
            <article class="timeline-item">
                <time class="timeline-date" datetime="{{ post.date }}">
                    <span class="timeline-year">{{ post.date | date('YYYY') }}</span>
                    <span class="timeline-separator">/</span>
                    <span class="timeline-month">{{ post.date | date('MM') }}</span>
                    <span class="timeline-separator">/</span>
                    <span class="timeline-day">{{ post.date | date('DD') }}</span>
                </time>

                <div class="timeline-marker"></div>

                <div class="timeline-content">
                    <a href="{{ post.url | url }}" class="timeline-link">
                        <h3 class="timeline-title">{{ post.data.title }}</h3>
                    </a>

                    <div class="timeline-meta">
                        {% if post.data.tags %}
                        <div class="timeline-tags">
                            {% for tag in post.data.tags %}
                            {% if tag != "post" and tag != "posts" %}
                            <a href="{{ '/tags/?name=' + tag | url }}" class="timeline-tag">{{ tag }}</a>
                            {% endif %}
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </article>
            {% endfor %}
        </div>
    </main>
</div>

<script>
    localStorage.setItem('_HISTORY', JSON.stringify([location.origin + location.pathname]))
</script>
