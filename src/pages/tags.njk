---
layout: base.njk
title: 标签
permalink: /tags/
---

<a
    id="back-to-tags"
    style="display: none;"
    href="javascript:void(0);"
    onclick="showAllTags()"
    class="nav-link"
    aria-label="Back to all tags"
>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
    >
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"
        />
    </svg>
    <span>All Tags</span>
</a>

<div class="tags-container">
    {# 标签云区域 #}
    <div id="tag-cloud" class="tag-cloud">
        {% set tagsByCount = [] %}
        {% for tag in collections.tagList %}
        {% set tagObj = { "name": tag, "count": collections[tag].length } %}
        {% set tagsByCount = (tagsByCount.push(tagObj), tagsByCount) %}
        {% endfor %}
        {% set sortedTags = tagsByCount | sort(false, false, "count") | reverse %}
        {% for tagObj in sortedTags %}
        <a
            href="javascript:void(0);"
            onclick="filterByTag('{{ tagObj.name }}')"
            class="tag-item"
            data-count="{{ tagObj.count }}"
            data-tag="{{ tagObj.name }}"
        >{{ tagObj.name }}<sup class="tag-count">{{ tagObj.count }}</sup></a>
        {% endfor %}
    </div>
    {# 文章列表区域 #}
    <div
        id="tag-posts"
        class="tag-posts"
        style="display: none;"
    >
        <div id="tag-title"></div>
        <div id="posts-list"></div>
    </div>
</div>

<script src="/assets/js/tag-cloud.js"></script>
<script>
  const allPosts = [{% for tag in collections.tagList %}{% for post in collections[tag] %}{
          title: {{ post.data.title | dump | safe }},
          url: {{ post.url | url | dump | safe }},
          date: {{ post.date | dump | safe }},
          tags: {{ post.data.tags | dump | safe }},
          excerpt: {{ post.templateContent | striptags | truncate(150) | dump | safe }}
        }
        {% if not loop.last or not loop.parent.last %},{% endif %}{% endfor %}{% endfor %}];

  function uniquePosts(posts) {
    const seen = new Set();
    return posts.filter(post => {
      if (seen.has(post.url)) return false;
      seen.add(post.url);
      return true;
    });
  }

  let destroyCloud = null;

  function showAllTags() {
    const url = new URL(window.location);
    url.searchParams.delete('name');
    window.history.pushState({}, '', url);

    document.getElementById('tag-cloud').style.display = '';
    document.getElementById('tag-posts').style.display = 'none';
    document.getElementById('back-to-tags').style.display = 'none';

    document.querySelectorAll('.tag-item').forEach(link => link.classList.remove('active'));
    localStorage.setItem('_HISTORY', JSON.stringify([location.origin + location.pathname]));

    // Re-init cloud
    if (!destroyCloud) {
      destroyCloud = initTagCloud(document.getElementById('tag-cloud'));
    }
  }

  function filterByTag(tagName) {
    // Destroy cloud before hiding
    if (destroyCloud) {
      destroyCloud();
      destroyCloud = null;
    }

    const url = new URL(window.location);
    url.searchParams.set('name', tagName);
    window.history.pushState({}, '', url);

    document.getElementById('tag-cloud').style.display = 'none';
    document.getElementById('tag-posts').style.display = 'block';
    document.getElementById('back-to-tags').style.display = 'inline-flex';

    document.querySelectorAll('.tag-item').forEach(link => {
      link.classList.toggle('active', link.getAttribute('data-tag') === tagName);
    });

    document.getElementById('tag-title').innerHTML = `<h2>${tagName}</h2>`;

    const filteredPosts = uniquePosts(
      allPosts.filter(post => post.tags && post.tags.includes(tagName))
    );

    const postsListElement = document.getElementById('posts-list');
    if (filteredPosts.length === 0) {
      postsListElement.innerHTML = '<p>没有找到相关文章</p>';
      return;
    }

    filteredPosts.sort((a, b) => new Date(b.date) - new Date(a.date));

    postsListElement.innerHTML = '<ul class="filtered-posts">' +
      filteredPosts.map(post =>
        `<li><a href="${post.url}">${post.title}</a><div class="post-excerpt">${post.excerpt}</div></li>`
      ).join('') + '</ul>';

    localStorage.setItem('_HISTORY', JSON.stringify([location.origin + location.pathname + location.search]));
  }

  // 3D Tag Cloud Engine
  document.addEventListener('DOMContentLoaded', function () {
    // URL param check — if filtering, skip cloud animation
    const urlParams = new URLSearchParams(window.location.search);
    const tagName = urlParams.get('name');
    if (tagName) {
      filterByTag(tagName);
      return;
    }
    showAllTags();
  });
</script>

<style>
  .tags-title {
    padding: 2rem 0 1rem;
  }

  .tags-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
    width: 98%;
  }

  /* 3D Tag Cloud */
  .tag-cloud {
    position: relative;
    width: 100%;
    height: 360px;
    margin-bottom: 2rem;
    overflow: hidden;
    cursor: grab;
    visibility: hidden;
  }

  @media (min-width: 500px) {
    .tag-cloud {
      height: 520px;
    }
  }

  @media (min-width: 768px) {
    .tag-cloud {
      height: 580px;
    }
  }

  .tag-item {
    position: absolute;
    top: 0;
    left: 0;
    white-space: nowrap;
    text-decoration: none;
    color: var(--c-color);
    cursor: pointer;
    user-select: none;
    will-change: transform, opacity;
    transition: color 0.15s ease;
    border-bottom: none !important;
    padding: 0.2em 0.4em;
    border-radius: 4px;
  }

  .tag-item::after {
    display: none !important;
  }

  @media (hover: hover) {
    .tag-item:hover {
      color: var(--fg-deeper);
      background: rgba(0, 0, 0, 0.04);
    }
    html.dark .tag-item:hover {
      background: rgba(255, 255, 255, 0.08);
    }
  }

  .tag-item.active {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .tag-count {
    font-size: 0.7em;
    opacity: 0.55;
    font-weight: 400;
    margin-left: 0.1em;
    vertical-align: super;
    line-height: 1;
  }

  /* prefers-reduced-motion: static fallback */
  @media (prefers-reduced-motion: reduce) {
    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1rem;
      justify-content: center;
      align-items: baseline;
      height: auto;
    }
    .tag-item {
      position: static;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  /* 文章列表 */
  .filtered-posts {
    list-style: none;
    padding: 0;
  }
  .filtered-posts li {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--c-border-color);
  }
  .filtered-posts a {
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    color: var(--c-color);
  }
  .post-excerpt {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--c-color);
    opacity: 0.5;
  }
</style>
